<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="260dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="22dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/divider">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvOfferBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_status_transit"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="@string/limited_offer"
            android:textColor="@color/primary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/ivOffer"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_edittext"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_image_24" />

        <TextView
            android:id="@+id/tvOfferTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:maxLines="2"
            android:text="@string/special_offer_title"
            android:textColor="@color/text_dark"
            android:textSize="18sp"
                android:fontFamily="@font/lama_sans_medium"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvOfferDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:maxLines="2"
            android:text="@string/special_offer_description"
            android:textColor="@color/text_grey"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/offerPriceRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvOfferPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/value_45_99"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvOriginalPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/value_45_99"
                android:textColor="@color/text_grey"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvOfferMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/offer_meta_example"
            android:textColor="@color/status_delivered_text"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
