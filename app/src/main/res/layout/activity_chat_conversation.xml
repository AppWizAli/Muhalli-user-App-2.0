<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:minHeight="?attr/actionBarSize"
        android:paddingHorizontal="8dp"
        app:navigationIcon="@drawable/ic_arrow_back_24"
        app:titleTextColor="@color/text_dark" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical"
        android:paddingStart="56dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp">

        <TextView
            android:id="@+id/tvSupplierLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dubai"
            android:textColor="@color/text_grey"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvSupplierStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_status_delivered"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="@string/online_for_media_and_voice_updates"
            android:textColor="@color/status_delivered_text"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingVertical="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageView
            android:id="@+id/layoutMediaAction"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/bg_chat_action_button"
            android:contentDescription="@null"
            android:padding="12dp"
            android:src="@drawable/ic_image_24"
            app:tint="@color/primary" />

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_edittext"
            android:hint="@string/type_a_message"
            android:inputType="textCapSentences|textMultiLine"
            android:paddingHorizontal="16dp"
            android:textSize="14sp" />

        <ImageView
            android:id="@+id/layoutVoiceAction"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_chat_action_button"
            android:contentDescription="@null"
            android:padding="12dp"
            android:src="@drawable/ic_mic_24"
            app:tint="@color/primary" />

        <ImageView
            android:id="@+id/layoutSendAction"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_badge"
            android:contentDescription="@null"
            android:padding="12dp"
            android:src="@drawable/ic_send_24"
            app:tint="@color/white" />
    </LinearLayout>
</LinearLayout>



