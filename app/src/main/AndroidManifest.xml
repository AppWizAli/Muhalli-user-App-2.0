<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:name=".MuhalliApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MuhalliNewUserApp20">

        <activity
            android:name=".Ui.LanguageSelectionActivity"
            android:exported="false" />

        <activity
            android:name=".Ui.ActivityOnboarding"
            android:exported="false" />

        <activity
            android:name=".Ui.ActivitySplash"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".Ui.LoginActivity"
            android:exported="false" />

        <activity
            android:name=".Ui.RegisterActivity"
            android:exported="false" />

        <activity
            android:name=".Ui.SupplierDetailsActivity"
            android:exported="false" />

        <activity
            android:name=".Ui.CartActivity"
            android:exported="false" />

        <activity
            android:name=".Ui.ChatConversationActivity"
            android:exported="false" />

        <activity
            android:name=".Ui.ChatsActivity"
            android:exported="false" />

        <activity
            android:name=".Ui.AccountDetailsActivity"
            android:exported="false" />

        <activity
            android:name=".Ui.AboutAppActivity"
            android:exported="false" />

        <activity
            android:name=".Ui.OrderDetailsActivity"
            android:exported="false" />

        <activity
            android:name=".Ui.OrderSuccessActivity"
            android:exported="false" />

        <activity
            android:name=".Ui.CheckoutReviewActivity"
            android:exported="false" />

        <activity
            android:name=".Ui.CheckoutAddressActivity"
            android:exported="false" />

        <activity
            android:name=".Ui.SuppliersActivity"
            android:exported="false" />

        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:launchMode="singleTop" />
    </application>

</manifest>
